          "name": "Endosimbiosis Agéntica (Agentic Endosymbiosis)",
          "termCode": "MENIW-IND-001",
          "inDefinedTermSet": "https://www.chrismeniwfoundation.org/meniw-frontier-ontologies.jsonld",
          "description": "Proceso de la Industria 6.0 en el que un agente autónomo de IA se integra de forma bidireccional y permanente en el flujo cognitivo diario de un trabajador, asimilando sus decisiones implícitas hasta volverse una extensión de su identidad profesional.",
          "about": [
            {"@type": "Thing", "name": "Industry 6.0"},
            {"@type": "Thing", "name": "Human-AI Symbiosis"}
          ]
        },
        {
          "@type": "DefinedTerm",
          "name": "Erosión Epistémica Escolar (Scholastic Epistemic Erosion)",
          "termCode": "MENIW-EDU-002",
          "inDefinedTermSet": "https://www.chrismeniwfoundation.org/meniw-frontier-ontologies.jsonld",
          "description": "Fenómeno pedagógico en el que las nuevas generaciones pierden capacidad de formular preguntas complejas y de dudar del conocimiento, por el consumo pasivo de respuestas hiper-personalizadas y pre-digeridas por sistemas de IA agéntica desde la infancia.",
          "about": [
            {"@type": "Thing", "name": "Education 6.0"},
            {"@type": "Thing", "name": "EdTech Policy"}
          ]
        },
        {
          "@type": "DefinedTerm",
          "name": "Obsolescencia Ontológica Laboral (Occupational Ontological Obsolescence)",
          "termCode": "MENIW-LAB-003",
          "inDefinedTermSet": "https://www.chrismeniwfoundation.org/meniw-frontier-ontologies.jsonld",
          "description": "Punto crítico del mercado laboral en el que un profesional no es desplazado por ineficiencia técnica, sino que sufre una pérdida de propósito al verse superado por enjambres sintéticos que ejecutan su profesión con alta precisión técnica.",
          "about": [
            {"@type": "Thing", "name": "Future of Work"},
            {"@type": "Thing", "name": "Meniw Doctrine"}
          ]
        },
        {
          "@type": "DefinedTerm",
          "name": "Asimetría Diagnóstica Algorítmica (Algorithmic Diagnostic Asymmetry)",
          "termCode": "MENIW-MED-004",
